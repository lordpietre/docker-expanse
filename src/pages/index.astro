---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
import Hero from "../components/widgets/Hero.astro";
import Features from "../components/widgets/Features.astro";
import Content2 from "../components/widgets/Content2.astro";
import expanseHeroImg from "../assets/images/expanse_hero.png";
import expanseNodesImg from "../assets/images/expanse_nodes.png";

const metadata = {
  title: `${siteConfig.name} — Visual Docker Compose Orchestration`,
  description:
    "Expanse is a professional-grade, open-source orchestration platform that transforms Docker Compose management into a fluid visual experience.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <Hero
    title={`Orchestrate Docker with <br class="hidden md:block" /> <span class="bg-linear-to-r from-teal-400 via-emerald-400 to-cyan-400 bg-clip-text text-transparent">nodes</span>`}
    tagline="Visual Infrastructure as Code"
    description="Design, deploy, and monitor your Docker infrastructure visually. Build with nodes, run with confidence, and stop writing YAML by hand."
    actions={[
      {
        text: "View on GitHub",
        href: "https://github.com/lordpietre/docker-expanse",
        variant: "primary",
        icon: "lucide:github",
      },
      {
        text: "Explore Features",
        href: "#features",
        variant: "secondary",
        icon: "lucide:arrow-down",
      },
    ]}
    image={{ src: expanseHeroImg, alt: "Expanse Node-Based Canvas" }}
  />

  <Features
    id="features"
    tagline="Visual Infrastructure"
    title="Design Without Limits"
    subtitle="Expanse turns every action on the canvas into a real deployment operation."
    features={[
      {
        title: "Node-Based Canvas",
        description:
          "Build architectures by composing nodes for Services, Networks, Volumes, and Environment Variables.",
        icon: "lucide:layout-template",
        iconClass: "bg-teal-500/10 text-teal-400",
      },
      {
        title: "Intelligent Auto-Injection",
        description:
          "Connecting a service to a database automatically propagates the required environment variables and network links.",
        icon: "lucide:zap",
        iconClass: "bg-emerald-500/10 text-emerald-400",
      },
      {
        title: "Auto-Layout",
        description: "Uses the Dagre algorithm to keep complex graphs clean and readable without manual positioning.",
        icon: "lucide:map",
        iconClass: "bg-cyan-500/10 text-cyan-400",
      },
    ]}
  />

  <Content2
    id="engine"
    items={[
      {
        title: "Deploy & Monitor",
        description: "Deploy, Stop, and Restart entire projects with a single action. Live CPU and Memory metrics refresh every 3 seconds.",
        icon: "lucide:activity",
        iconClass: "bg-teal-500/10 text-teal-400",
      },
      {
        title: "Live Log Streaming",
        description: "Integrated terminal for real-time log output from any running container directly in the UI.",
        icon: "lucide:terminal",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Auto-Port Reassignment",
        description: "Detects host port collisions at deploy time and reassigns them dynamically to prevent failures.",
        icon: "lucide:shuffle",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
    ]}
    image={expanseNodesImg}
    imageAlt="Execution Engine"
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        A Live Execution Engine
      </h3>
      Expanse communicates directly with the Docker daemon, turning your visual designs into production-ready deployments instantly.
    </Fragment>
  </Content2>

  <Features
    id="tech-stack"
    tagline="Technology"
    title="Built for Performance"
    subtitle="Powered by modern, high-performance technologies for a seamless experience."
    features={[
      {
        title: "Next.js 15 & React 19",
        description: "The latest web standards for speed and modern reactivity.",
        icon: "lucide:cpu",
        iconClass: "bg-zinc-500/10 text-zinc-400",
      },
      {
        title: "React Flow",
        description: "A powerful node-based engine for high-performance visual interaction.",
        icon: "lucide:workflow",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Tailwind CSS & Framer Motion",
        description: "Sleek, responsive styling with smooth micro-animations.",
        icon: "lucide:palette",
        iconClass: "bg-pink-500/10 text-pink-400",
      },
    ]}
  />
</BaseLayout>
